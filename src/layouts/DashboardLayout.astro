---
import BaseLayout from "./BaseLayout.astro";
import { DashboardShell } from "@/components/dashboard/DashboardShell";
import { getDashboardProfileJson, shellProfileFromJson } from "@/lib/dashboard-profile";

interface Props {
  title?: string;
}

const { title = "Dashboard - Pacto Ágil" } = Astro.props;
const currentPath = Astro.url.pathname;

const user = Astro.locals.user;
let initialShellProfile = null;

if (user?.id) {
  try {
    const json = await getDashboardProfileJson(user.id, user.email ?? null);
    initialShellProfile = shellProfileFromJson(json);
  } catch {
    initialShellProfile = null;
  }
}
---

<BaseLayout title={title}>
  <DashboardShell
    client:idle
    currentPath={currentPath}
    initialShellProfile={initialShellProfile}
  >
    <slot />
  </DashboardShell>
</BaseLayout>
