---
import '../styles/globals.css';


import { ThemeToggle } from '@/components/ui/ThemeToggle';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Pacto Ágil - Negociações coletivas com inteligência',
  description = 'Micro-SaaS para sindicatos e escritórios trabalhistas: análise, criação e gestão de ACT e CCT com fluxo inteligente.'
} = Astro.props;
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <!-- Viewport otimizado para mobile: previne zoom, mantém largura responsiva -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Meta Cache-Control -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo-pacto-agil-new.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Fonts (Replicando next/font) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style is:global>
      :root {
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-serif: 'Playfair Display', serif;
        --font-mono: 'JetBrains Mono', monospace;
      }
    </style>

    <!-- Theme Detection Script -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('pacto-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="font-sans antialiased bg-background text-foreground min-h-screen relative flex flex-col selection:bg-accent selection:text-accent-foreground overflow-x-hidden">
    <div class="bg-noise"></div>
    <ThemeToggle client:idle />
    
    <slot />

    <!-- Sincronização e Limpeza de Cache (Definitivo) -->
    <script is:inline>
      (function() {
        if (!('serviceWorker' in navigator)) return;

        // Função para forçar refresh pesado
        function forceSync() {
          console.log('[Pacto] Resíduo do Next.js detectado. Iniciando reset profundo...');
          window.location.replace('/reset?reason=legacy_detected&ts=' + Date.now());
        }

        // 1. Detectar sinalizadores do Next.js ativos na janela
        if (window.__NEXT_DATA__ || window.next || document.getElementById('__NEXT_DATA__')) {
            forceSync();
            return;
        }

        // 2. Detectar Service Workers antigos
        navigator.serviceWorker.getRegistrations().then(function(registrations) {
          for (var reg of registrations) {
            var sw = reg.active || reg.installing || reg.waiting;
            if (sw && sw.scriptURL && (sw.scriptURL.indexOf('_next') !== -1 || sw.scriptURL.indexOf('next') !== -1)) {
              forceSync();
              return;
            }
          }

          // Registrar nosso novo "limpador" (sw.js)
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).then(function(reg) {
            reg.update();
          }).catch(function(err) {
            console.error('[Pacto] Erro ao registrar limpador:', err);
          });
        });

        // 3. Capturar erros típicos de cache corrompido
        window.addEventListener('error', function(e) {
          var msg = e.message || '';
          var src = (e.filename || '');
          if (
            src.indexOf('_next') !== -1 || 
            msg.indexOf('ChunkLoadError') !== -1 || 
            msg.indexOf('unexpected token <') !== -1 || 
            msg.indexOf('MIME') !== -1
          ) {
            forceSync();
          }
        }, true);
      })();
    </script>
  </body>
</html>
