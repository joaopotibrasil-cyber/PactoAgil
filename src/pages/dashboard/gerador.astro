---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import { GeradorPageContent } from "@/components/dashboard/GeradorPageContent";
import { supabase } from "@/lib/supabase/astro";

const { data: { user }, error } = await supabase(Astro.cookies).auth.getUser();

if (error || !user) {
  return Astro.redirect("/login");
}
---

<DashboardLayout title="Gerador Inteligente - Pacto Ágil">
  <GeradorPageContent client:only="react" />
</DashboardLayout>
