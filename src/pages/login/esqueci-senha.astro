---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Recuperar senha - Pacto Ágil">
  <main class="min-h-screen flex items-center justify-center px-6">
    <section class="section-shell w-full max-w-xl p-8 md:p-10 text-center space-y-5">
      <h1 class="text-3xl font-semibold tracking-tight">Recuperação de senha</h1>
      <p class="text-foreground/70">
        Para redefinir sua senha, entre em contato com o administrador da sua entidade
        ou solicite suporte pelo canal oficial da plataforma.
      </p>
      <a
        href="/login"
        class="inline-flex items-center justify-center rounded-full bg-primary text-primary-foreground px-6 py-3 text-sm font-semibold magnetic"
      >
        Voltar para login
      </a>
    </section>
  </main>
</BaseLayout>
